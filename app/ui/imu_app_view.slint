import { BackChip } from "widgets.slint";

export component ImuAppView inherits Rectangle {
    in property <float> tilt_ratio: 0.5;
    callback back();

    property <int> tilt_zone: root.tilt_ratio > 0.66 ? 2 : (root.tilt_ratio < 0.34 ? 0 : 1);
    property <string> tilt_state: root.tilt_zone == 2 ? "UP" : (root.tilt_zone == 0 ? "DOWN" : "LEVEL");
    property <color> tilt_color: root.tilt_zone == 2 ? #ff8b59 : (root.tilt_zone == 0 ? #5ca8ff : #30c897);

    background: #0b1324;
    border-radius: 30px;

    BackChip {
        x: 16px;
        y: 16px;
        tapped => {
            root.back();
        }
    }

    Text {
        x: 98px;
        y: 22px;
        text: "IMU";
        color: #eaf1ff;
        font-size: 24px;
    }

    Rectangle {
        x: 16px;
        y: 68px;
        width: parent.width - 32px;
        height: 312px;
        border-radius: 24px;
        border-width: 1px;
        border-color: #2b3652;
        background: #121d33;

        Text {
            x: 18px;
            y: 18px;
            text: "TILT STATE";
            color: #88a0d0;
            font-size: 13px;
        }

        Text {
            x: 18px;
            y: 56px;
            width: parent.width - 36px;
            text: root.tilt_state;
            color: root.tilt_color;
            font-size: 50px;
            horizontal-alignment: center;
        }

        bar_track := Rectangle {
            x: 18px;
            y: 152px;
            width: parent.width - 36px;
            height: 36px;
            border-radius: 18px;
            border-width: 1px;
            border-color: #34415f;
            background: #1c2843;
            clip: true;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width * root.tilt_ratio;
                height: parent.height;
                border-radius: 18px;
                background: root.tilt_color;
            }
        }

        Rectangle {
            width: 14px;
            height: bar_track.height + 10px;
            x: bar_track.x + (bar_track.width - self.width) * root.tilt_ratio;
            y: bar_track.y - 5px;
            border-radius: 7px;
            border-width: 1px;
            border-color: #ffffff;
            background: #dce9ff;
        }

        Text {
            x: 18px;
            y: 210px;
            width: parent.width - 36px;
            text: "Keep marker around center";
            color: #94a9d3;
            font-size: 14px;
            horizontal-alignment: center;
        }

        Text {
            x: 18px;
            y: 248px;
            width: parent.width - 36px;
            text: "Blue: down  Green: level  Orange: up";
            color: #7288b4;
            font-size: 12px;
            horizontal-alignment: center;
        }
    }
}
