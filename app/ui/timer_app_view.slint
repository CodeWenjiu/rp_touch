import { BackChip } from "widgets.slint";

export component TimerAppView inherits Rectangle {
    in property <int> ui_seconds: 0;
    callback back();

    property <int> sec_in_minute: Math.mod(root.ui_seconds, 60);
    property <bool> pulse_on: Math.mod(root.ui_seconds, 2) == 0;

    background: #0b1324;
    border-radius: 30px;

    BackChip {
        x: 16px;
        y: 16px;
        tapped => {
            root.back();
        }
    }

    Text {
        x: 98px;
        y: 22px;
        text: "TIMER";
        color: #eaf1ff;
        font-size: 24px;
    }

    Rectangle {
        x: 16px;
        y: 68px;
        width: parent.width - 32px;
        height: 312px;
        border-radius: 24px;
        border-width: 1px;
        border-color: #2b3652;
        background: #121d33;

        Text {
            x: 18px;
            y: 18px;
            text: "ELAPSED";
            color: #88a0d0;
            font-size: 13px;
        }

        Text {
            x: 18px;
            y: 58px;
            width: parent.width - 36px;
            text: root.ui_seconds + "s";
            color: #f7f9ff;
            font-size: 56px;
            horizontal-alignment: center;
        }

        Text {
            x: 18px;
            y: 128px;
            width: parent.width - 36px;
            text: (root.ui_seconds / 60) + "m " + root.sec_in_minute + "s";
            color: #9bb0d8;
            font-size: 18px;
            horizontal-alignment: center;
        }

        Rectangle {
            x: 18px;
            y: 178px;
            width: parent.width - 36px;
            height: 28px;
            border-radius: 14px;
            border-width: 1px;
            border-color: #34415f;
            background: #1c2843;
            clip: true;

            Rectangle {
                x: 0px;
                y: 0px;
                width: (parent.width * root.sec_in_minute) / 60;
                height: parent.height;
                border-radius: 14px;
                background: #5ea8ff;
            }
        }

        Rectangle {
            x: (parent.width / 2) - 16px;
            y: 236px;
            width: 32px;
            height: 32px;
            border-radius: 16px;
            background: root.pulse_on ? #37d09b : #23304c;
            border-width: 1px;
            border-color: #41557e;
        }

        Text {
            x: 18px;
            y: 274px;
            width: parent.width - 36px;
            text: "1Hz heartbeat";
            color: #8ea4d1;
            font-size: 14px;
            horizontal-alignment: center;
        }
    }
}
