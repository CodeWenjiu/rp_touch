import { WatchHomeView } from "app/watch_home.slint";
import { ImuAppView } from "app/apps/imu_app_view.slint";
import { TimerAppView } from "app/apps/timer_app_view.slint";

export component AppUi inherits Window {
    width: 280px;
    height: 456px;

    in-out property <float> tilt_ratio: 0.5;
    in-out property <int> ui_seconds: 0;
    in-out property <int> ui_fps: 0;
    in-out property <bool> ui_touch_active: false;
    in-out property <int> ui_touch_x: 0;
    in-out property <int> ui_touch_y: 0;
    in-out property <int> active_page: 0;
    in-out property <int> home_panel_state: 0;

    ui_timer := Timer {
        interval: 1s;
        running: true;
        triggered => {
            root.ui_seconds += 1;
        }
    }

    Rectangle {
        background: #050914;

        WatchHomeView {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;
            visible: root.active_page == 0;
            tilt_ratio: root.tilt_ratio;
            ui_seconds: root.ui_seconds;
            panel_state: root.home_panel_state;
            open_imu => {
                root.active_page = 1;
                root.home_panel_state = 1;
            }
            open_timer => {
                root.active_page = 2;
                root.home_panel_state = 1;
            }
        }

        ImuAppView {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;
            visible: root.active_page == 1;
            tilt_ratio: root.tilt_ratio;
            back => {
                root.active_page = 0;
                root.home_panel_state = 1;
            }
        }

        TimerAppView {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;
            visible: root.active_page == 2;
            ui_seconds: root.ui_seconds;
            back => {
                root.active_page = 0;
                root.home_panel_state = 1;
            }
        }

        Text {
            x: parent.width - 80px;
            y: 4px;
            width: 72px;
            text: root.ui_fps + "fps";
            color: #9cb3df;
            font-size: 12px;
            horizontal-alignment: right;
        }

        Rectangle {
            visible: root.ui_touch_active;
            width: 28px;
            height: 28px;
            x: root.ui_touch_x * 1px - (self.width / 2);
            y: root.ui_touch_y * 1px - (self.height / 2);
            border-radius: 14px;
            border-width: 2px;
            border-color: #8fd7ff;
            background: #ffffff33;
        }

        Rectangle {
            visible: root.ui_touch_active;
            width: 8px;
            height: 8px;
            x: root.ui_touch_x * 1px - (self.width / 2);
            y: root.ui_touch_y * 1px - (self.height / 2);
            border-radius: 4px;
            background: #8fd7ff;
        }
    }
}
