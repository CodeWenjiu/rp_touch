export component AppIconTile inherits Rectangle {
    in property <string> title: "";
    in property <string> subtitle: "";
    in property <string> icon_text: "";
    in property <color> accent: #4aa1ff;
    callback tapped();

    border-radius: 20px;
    border-width: 1px;
    border-color: #2b3652;
    background: tile_touch.pressed ? #1c2740 : #121b2d;
    clip: true;

    Rectangle {
        x: 14px;
        y: 14px;
        width: 46px;
        height: 46px;
        border-radius: 23px;
        background: root.accent;
    }

    Text {
        x: 14px;
        y: 20px;
        width: 46px;
        text: root.icon_text;
        color: #ffffff;
        font-size: 22px;
        horizontal-alignment: center;
    }

    Text {
        x: 14px;
        y: 70px;
        width: parent.width - 28px;
        text: root.title;
        color: #f4f7ff;
        font-size: 20px;
    }

    Text {
        x: 14px;
        y: 98px;
        width: parent.width - 28px;
        text: root.subtitle;
        color: #9eb0d7;
        font-size: 13px;
    }

    tile_touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.tapped();
        }
    }
}

export component BackChip inherits Rectangle {
    callback tapped();

    width: 74px;
    height: 34px;
    border-radius: 17px;
    border-width: 1px;
    border-color: #2b3652;
    background: back_touch.pressed ? #202c46 : #131d30;

    Text {
        x: 0px;
        y: 8px;
        width: parent.width;
        text: "< Back";
        color: #d9e3ff;
        font-size: 13px;
        horizontal-alignment: center;
    }

    back_touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.tapped();
        }
    }
}
