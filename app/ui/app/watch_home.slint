import { AppListTile } from "widgets.slint";

export component WatchHomeView inherits Rectangle {
    in property <float> tilt_ratio: 0.5;
    in property <int> ui_temp_c: 0;
    in property <int> ui_imu_temp_c: 0;
    in property <int> ui_cpu_mhz: 0;
    in property <int> ui_seconds: 0;
    in-out property <int> panel_state: 0; // 0: main, 1: apps
    callback open_imu();
    callback open_timer();

    function pad2(value: int) -> string {
        return value < 10 ? "0" + value : "" + value;
    }

    property <int> hours: Math.mod(root.ui_seconds / 3600, 24);
    property <int> minutes: Math.mod(root.ui_seconds / 60, 60);
    property <int> seconds: Math.mod(root.ui_seconds, 60);
    property <string> hhmm: root.pad2(root.hours) + ":" + root.pad2(root.minutes);
    property <string> ss: root.pad2(root.seconds);

    property <int> tilt_zone: root.tilt_ratio > 0.66 ? 2 : (root.tilt_ratio < 0.34 ? 0 : 1);
    property <string> tilt_state: root.tilt_zone == 2 ? "UP" : (root.tilt_zone == 0 ? "DOWN" : "LEVEL");
    property <length> stack_offset_x: root.panel_state == 1 ? root.width + 14px : 0px;

    background: #080e1a;
    border-radius: 30px;
    clip: true;

    swipe := SwipeGestureHandler {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        handle-swipe-right: root.panel_state == 0;
        handle-swipe-left: root.panel_state == 1;
        swiped => {
            root.panel_state = root.panel_state == 0 ? 1 : 0;
        }
    }

    stack := Rectangle {
        x: root.stack_offset_x;
        y: 0px;
        width: parent.width * 2 + 14px;
        height: parent.height;
        background: #00000000;
        animate x {
            duration: 220ms;
            easing: ease-in-out;
        }

        // App list page (revealed by swiping right from main page)
        Rectangle {
            x: -(root.width + 14px);
            y: 0px;
            width: root.width;
            height: root.height;
            background: #0a1221;

            Rectangle {
                x: 14px;
                y: 14px;
                width: parent.width - 28px;
                height: 58px;
                border-radius: 18px;
                border-width: 1px;
                border-color: #2b3652;
                background: #121d33;

                Text {
                    x: 16px;
                    y: 10px;
                    text: "Applications";
                    color: #eef4ff;
                    font-size: 24px;
                }

                Text {
                    x: 16px;
                    y: 36px;
                    text: "Swipe left to return";
                    color: #8fa3cc;
                    font-size: 13px;
                }
            }

            AppListTile {
                x: 16px;
                y: 90px;
                width: parent.width - 32px;
                height: 130px;
                title: "IMU";
                subtitle: "Tilt monitor and balance";
                icon: @image-url("assets/imu_icon.svg");
                accent: #66a6ff;
                tapped => {
                    root.open_imu();
                }
                swipe_left => {
                    root.panel_state = 0;
                }
            }

            AppListTile {
                x: 16px;
                y: 234px;
                width: parent.width - 32px;
                height: 130px;
                title: "Timer";
                subtitle: "System heartbeat clock";
                icon: @image-url("assets/timer_icon.svg");
                accent: #66a6ff;
                tapped => {
                    root.open_timer();
                }
                swipe_left => {
                    root.panel_state = 0;
                }
            }
        }

        // Main watch page
        Rectangle {
            x: 0px;
            y: 0px;
            width: root.width;
            height: root.height;
            background: #0a1221;

            Rectangle {
                x: 14px;
                y: 14px;
                width: parent.width - 28px;
                height: 258px;
                border-radius: 26px;
                border-width: 1px;
                border-color: #2a3550;
                background: #121d33;

                Text {
                    x: 16px;
                    y: 14px;
                    text: "RP WATCH";
                    color: #91a6d0;
                    font-size: 14px;
                }

                Rectangle {
                    x: parent.width - 54px;
                    y: 18px;
                    width: 38px;
                    height: 18px;
                    border-radius: 9px;
                    background: #233451;
                    Text {
                        x: 0px;
                        y: 2px;
                        width: parent.width;
                        text: "LIVE";
                        color: #b6ccf3;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }

                Text {
                    x: 16px;
                    y: 58px;
                    text: root.hhmm;
                    color: #f4f8ff;
                    font-size: 62px;
                }

                Text {
                    x: 190px;
                    y: 106px;
                    text: root.ss;
                    color: #a9bcdf;
                    font-size: 24px;
                }

                Rectangle {
                    x: 16px;
                    y: 148px;
                    width: parent.width - 32px;
                    height: 88px;
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: #33405f;
                    background: #1a2742;

                    Text {
                        x: 14px;
                        y: 8px;
                        text: "CPU TEMP";
                        color: #88a0d0;
                        font-size: 12px;
                    }

                    Text {
                        x: 14px;
                        y: 24px;
                        text: root.ui_temp_c + " C";
                        color: #f2f7ff;
                        font-size: 24px;
                    }

                    Text {
                        x: 14px;
                        y: 54px;
                        text: "IMU TEMP";
                        color: #6a849b;
                        font-size: 11px;
                    }

                    Text {
                        x: 14px;
                        y: 66px;
                        text: root.ui_imu_temp_c + " C";
                        color: #c5d9ef;
                        font-size: 17px;
                    }

                    Text {
                        x: parent.width - 120px;
                        y: 20px;
                        width: 106px;
                        text: "CPU";
                        color: #8ea4cf;
                        font-size: 12px;
                        horizontal-alignment: right;
                    }

                    Text {
                        x: parent.width - 120px;
                        y: 36px;
                        width: 106px;
                        text: root.ui_cpu_mhz + " MHz";
                        color: #dbe7ff;
                        font-size: 19px;
                        horizontal-alignment: right;
                    }
                }
            }
        }
    }
}
