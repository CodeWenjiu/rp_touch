import { AppListTile } from "widgets.slint";

export component WatchHomeView inherits Rectangle {
    in property <float> tilt_ratio: 0.5;
    in property <int> ui_seconds: 0;
    in-out property <int> panel_state: 0; // 0: main, 1: apps
    callback open_imu();
    callback open_timer();

    function pad2(value: int) -> string {
        return value < 10 ? "0" + value : "" + value;
    }

    property <int> hours: Math.mod(root.ui_seconds / 3600, 24);
    property <int> minutes: Math.mod(root.ui_seconds / 60, 60);
    property <int> seconds: Math.mod(root.ui_seconds, 60);
    property <string> hhmm: root.pad2(root.hours) + ":" + root.pad2(root.minutes);
    property <string> ss: root.pad2(root.seconds);

    property <int> tilt_zone: root.tilt_ratio > 0.66 ? 2 : (root.tilt_ratio < 0.34 ? 0 : 1);
    property <string> tilt_state: root.tilt_zone == 2 ? "UP" : (root.tilt_zone == 0 ? "DOWN" : "LEVEL");
    property <color> tilt_color: root.tilt_zone == 2 ? #ff8b59 : (root.tilt_zone == 0 ? #5ca8ff : #30c897);
    property <length> stack_offset: root.panel_state == 1 ? root.height + 14px : 0px;

    background: #080e1a;
    border-radius: 30px;
    clip: true;

    swipe := SwipeGestureHandler {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        handle-swipe-down: root.panel_state == 0;
        handle-swipe-up: root.panel_state == 1;
        swiped => {
            // Built-in swipe recognition already applies direction + distance thresholds.
            // Avoid adding a second, too-aggressive threshold here.
            root.panel_state = root.panel_state == 0 ? 1 : 0;
        }
    }

    stack := Rectangle {
        x: 0px;
        y: root.stack_offset;
        width: parent.width;
        height: parent.height * 2 + 14px;
        background: #00000000;
        animate y {
            duration: 220ms;
            easing: ease-in-out;
        }

        // App list page (revealed by swipe down)
        Rectangle {
            x: 0px;
            y: -(root.height + 14px);
            width: root.width;
            height: root.height;
            background: #0a1221;

            Rectangle {
                x: 14px;
                y: 14px;
                width: parent.width - 28px;
                height: 58px;
                border-radius: 18px;
                border-width: 1px;
                border-color: #2b3652;
                background: #121d33;

                Text {
                    x: 16px;
                    y: 10px;
                    text: "Applications";
                    color: #eef4ff;
                    font-size: 24px;
                }

                Text {
                    x: 16px;
                    y: 36px;
                    text: "Swipe up to return";
                    color: #8fa3cc;
                    font-size: 13px;
                }
            }

            AppListTile {
                x: 16px;
                y: 90px;
                width: parent.width - 32px;
                height: 130px;
                title: "IMU";
                subtitle: "Tilt monitor and balance";
                icon: @image-url("assets/imu_icon.svg");
                accent: root.tilt_color;
                tapped => {
                    root.open_imu();
                }
            }

            AppListTile {
                x: 16px;
                y: 234px;
                width: parent.width - 32px;
                height: 130px;
                title: "Timer";
                subtitle: "System heartbeat clock";
                icon: @image-url("assets/timer_icon.svg");
                accent: #66a6ff;
                tapped => {
                    root.open_timer();
                }
            }
        }

        // Main watch page
        Rectangle {
            x: 0px;
            y: 0px;
            width: root.width;
            height: root.height;
            background: #0a1221;

            Rectangle {
                x: 14px;
                y: 14px;
                width: parent.width - 28px;
                height: 258px;
                border-radius: 26px;
                border-width: 1px;
                border-color: #2a3550;
                background: #121d33;

                Text {
                    x: 16px;
                    y: 14px;
                    text: "RP WATCH";
                    color: #91a6d0;
                    font-size: 14px;
                }

                Rectangle {
                    x: parent.width - 54px;
                    y: 18px;
                    width: 38px;
                    height: 18px;
                    border-radius: 9px;
                    background: #233451;
                    Text {
                        x: 0px;
                        y: 2px;
                        width: parent.width;
                        text: "LIVE";
                        color: #b6ccf3;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }

                Text {
                    x: 16px;
                    y: 58px;
                    text: root.hhmm;
                    color: #f4f8ff;
                    font-size: 62px;
                }

                Text {
                    x: 190px;
                    y: 106px;
                    text: root.ss;
                    color: #a9bcdf;
                    font-size: 24px;
                }

                Rectangle {
                    x: 16px;
                    y: 148px;
                    width: parent.width - 32px;
                    height: 84px;
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: #33405f;
                    background: #1a2742;

                    Text {
                        x: 14px;
                        y: 11px;
                        text: "IMU STATUS";
                        color: #88a0d0;
                        font-size: 12px;
                    }

                    Rectangle {
                        x: 14px;
                        y: 34px;
                        width: 104px;
                        height: 36px;
                        border-radius: 18px;
                        background: root.tilt_color;
                        Text {
                            x: 0px;
                            y: 8px;
                            width: parent.width;
                            text: root.tilt_state;
                            color: #ffffff;
                            font-size: 15px;
                            horizontal-alignment: center;
                        }
                    }

                    Rectangle {
                        x: 126px;
                        y: 41px;
                        width: parent.width - 140px;
                        height: 20px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: #40517a;
                        background: #223252;
                        clip: true;

                        Rectangle {
                            x: 0px;
                            y: 0px;
                            width: parent.width * root.tilt_ratio;
                            height: parent.height;
                            border-radius: 10px;
                            background: root.tilt_color;
                        }
                    }
                }
            }

            Rectangle {
                x: 14px;
                y: 286px;
                width: parent.width - 28px;
                height: 132px;
                border-radius: 24px;
                border-width: 1px;
                border-color: #2a3550;
                background: #101a2d;

                Text {
                    x: 16px;
                    y: 18px;
                    width: parent.width - 32px;
                    text: "Swipe down for apps";
                    color: #dbe7ff;
                    font-size: 22px;
                    horizontal-alignment: center;
                }

                Text {
                    x: 16px;
                    y: 60px;
                    width: parent.width - 32px;
                    text: "IMU and Timer are ready";
                    color: #8ea4cf;
                    font-size: 14px;
                    horizontal-alignment: center;
                }

                Rectangle {
                    x: (parent.width / 2) - 18px;
                    y: 94px;
                    width: 36px;
                    height: 22px;
                    border-radius: 11px;
                    background: #223252;

                    Text {
                        x: 0px;
                        y: 1px;
                        width: parent.width;
                        text: "v";
                        color: #dbe7ff;
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                }
            }
        }
    }
}
