export component AppListTile inherits Rectangle {
    in property <string> title: "";
    in property <string> subtitle: "";
    in property <image> icon;
    in property <color> accent: #4aa1ff;
    callback tapped();

    border-radius: 20px;
    border-width: 1px;
    border-color: #2a3550;
    background: touch.pressed ? #1e2a42 : #131d31;
    clip: true;

    Rectangle {
        x: 14px;
        y: 14px;
        width: 52px;
        height: 52px;
        border-radius: 26px;
        background: root.accent;
    }

    Image {
        x: 24px;
        y: 24px;
        width: 32px;
        height: 32px;
        source: root.icon;
        image-fit: contain;
    }

    Text {
        x: 80px;
        y: 18px;
        width: parent.width - 94px;
        text: root.title;
        color: #edf3ff;
        font-size: 24px;
    }

    Text {
        x: 80px;
        y: 50px;
        width: parent.width - 94px;
        text: root.subtitle;
        color: #9fb2d8;
        font-size: 14px;
    }

    Rectangle {
        x: parent.width - 34px;
        y: (parent.height / 2) - 10px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: #26324a;

        Text {
            x: 0px;
            y: 1px;
            width: parent.width;
            text: ">";
            color: #dbe7ff;
            font-size: 14px;
            horizontal-alignment: center;
        }
    }

    touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.tapped();
        }
    }
}

export component BackChip inherits Rectangle {
    callback tapped();

    width: 84px;
    height: 36px;
    border-radius: 18px;
    border-width: 1px;
    border-color: #2b3752;
    background: back_touch.pressed ? #1e2a42 : #121b2f;

    Text {
        x: 0px;
        y: 9px;
        width: parent.width;
        text: "< Back";
        color: #dce7ff;
        font-size: 13px;
        horizontal-alignment: center;
    }

    back_touch := TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        clicked => {
            root.tapped();
        }
    }
}
