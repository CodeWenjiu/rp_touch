import { BackChip } from "../widgets.slint";

export component ImuAppView inherits Rectangle {
    in property <int> pitch_deg: 0;
    in property <int> roll_deg: 0;
    callback back();

    function clamp_unit(v: float) -> float {
        return Math.max(-1.0, Math.min(1.0, v));
    }

    property <bool> is_level: Math.abs(root.pitch_deg) <= 2 && Math.abs(root.roll_deg) <= 2;
    property <color> level_color: root.is_level ? #30c897 : #ff8b59;
    property <float> norm_pitch: root.clamp_unit(root.pitch_deg / 30.0);
    property <float> norm_roll: root.clamp_unit(root.roll_deg / 30.0);

    background: #0a1221;
    border-radius: 30px;
    clip: true;

    BackChip {
        x: 16px;
        y: 14px;
        tapped => {
            root.back();
        }
    }

    Text {
        x: 96px;
        y: 20px;
        text: "LEVEL";
        color: #eef4ff;
        font-size: 24px;
    }

    Image {
        x: parent.width - 52px;
        y: 16px;
        width: 32px;
        height: 32px;
        source: @image-url("../assets/imu_icon.svg");
        image-fit: contain;
    }

    Rectangle {
        x: 16px;
        y: 64px;
        width: parent.width - 32px;
        height: 316px;
        border-radius: 24px;
        border-width: 1px;
        border-color: #2b3652;
        background: #121d33;

        Text {
            x: 0px;
            y: 14px;
            width: parent.width;
            text: root.is_level ? "LEVEL LOCKED" : "ADJUST DEVICE";
            color: root.level_color;
            font-size: 15px;
            horizontal-alignment: center;
        }

        // Bubble level field
        Rectangle {
            x: (parent.width / 2) - 96px;
            y: 40px;
            width: 192px;
            height: 192px;
            border-radius: 96px;
            border-width: 2px;
            border-color: #3d4d70;
            background: #182641;
            clip: true;

            Rectangle {
                x: 20px;
                y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;
                border-radius: (self.width / 2);
                border-width: 1px;
                border-color: #304262;
                background: #00000000;
            }

            Rectangle {
                x: (parent.width / 2) - 1px;
                y: 22px;
                width: 2px;
                height: parent.height - 44px;
                background: #2f4263;
            }

            Rectangle {
                x: 22px;
                y: (parent.height / 2) - 1px;
                width: parent.width - 44px;
                height: 2px;
                background: #2f4263;
            }

            Rectangle {
                width: 28px;
                height: 28px;
                x: (parent.width / 2) + root.norm_roll * 62px - (self.width / 2);
                y: (parent.height / 2) - root.norm_pitch * 62px - (self.height / 2);
                border-radius: 14px;
                border-width: 2px;
                border-color: #ffffffaa;
                background: root.level_color;
                animate x {
                    duration: 70ms;
                    easing: ease-out;
                }
                animate y {
                    duration: 70ms;
                    easing: ease-out;
                }
            }
        }

        Rectangle {
            x: 14px;
            y: 248px;
            width: (parent.width / 2) - 21px;
            height: 54px;
            border-radius: 14px;
            border-width: 1px;
            border-color: #334361;
            background: #1a2742;

            Text {
                x: 0px;
                y: 8px;
                width: parent.width;
                text: "PITCH";
                color: #8fa5d1;
                font-size: 11px;
                horizontal-alignment: center;
            }

            Text {
                x: 0px;
                y: 24px;
                width: parent.width;
                text: root.pitch_deg + " deg";
                color: #e8f1ff;
                font-size: 18px;
                horizontal-alignment: center;
            }
        }

        Rectangle {
            x: (parent.width / 2) + 7px;
            y: 248px;
            width: (parent.width / 2) - 21px;
            height: 54px;
            border-radius: 14px;
            border-width: 1px;
            border-color: #334361;
            background: #1a2742;

            Text {
                x: 0px;
                y: 8px;
                width: parent.width;
                text: "ROLL";
                color: #8fa5d1;
                font-size: 11px;
                horizontal-alignment: center;
            }

            Text {
                x: 0px;
                y: 24px;
                width: parent.width;
                text: root.roll_deg + " deg";
                color: #e8f1ff;
                font-size: 18px;
                horizontal-alignment: center;
            }
        }
    }
}
